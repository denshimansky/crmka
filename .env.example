# PostgreSQL — POSTGRES_PASSWORD обязателен (docker-compose упадёт если пусто)
POSTGRES_DB=crmka
POSTGRES_USER=crmka
POSTGRES_PASSWORD=change-me-strong-password

# App
# DATABASE_URL должна совпадать по password/user/db с POSTGRES_* выше
DATABASE_URL="postgresql://crmka:change-me-strong-password@db:5432/crmka?schema=public"
NEXTAUTH_URL="https://dev.umnayacrm.ru"
# Генерация: `openssl rand -hex 32` — обязательно ≥32 символов, иначе app падает в production
NEXTAUTH_SECRET="change-me-to-random-64-char-string"
NODE_ENV=production

# Telegram alerts (для деплоя + бэкапов)
# Бот: BotFather → /newbot. Chat ID: написать боту, открыть https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# AI-ассистент CRM (/api/ai/chat). Если ключ выбранного провайдера не задан —
# помощник отвечает «временно недоступен».
# ВНИМАНИЕ: OpenAI и Anthropic блокируют часть российских IP (в т.ч. MSK) — на
# заблокированном хосте задайте *_BASE_URL на релей с незаблокированным egress.

# Провайдер: "anthropic" (по умолчанию, Claude Haiku 4.5) или "openai" (gpt-5.4-mini).
AI_PROVIDER="anthropic"

# --- Anthropic (Claude) ---
# Ключ: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=""
# Модель по умолчанию claude-haiku-4-5 (самый дешёвый/быстрый тир). Пусто = дефолт.
ANTHROPIC_MODEL=""
# База Anthropic API (БЕЗ /v1 на конце). По умолчанию https://api.anthropic.com.
# Для заблокированного хоста — адрес релея, напр. https://<домен-релея>/anthropic.
ANTHROPIC_BASE_URL=""

# --- OpenAI ---
# Ключ: https://platform.openai.com/api-keys
OPENAI_API_KEY=""
# Модель по умолчанию gpt-5.4-mini. Альтернативы: gpt-5.4-nano / gpt-5.5. Пусто = дефолт.
OPENAI_MODEL=""
# База OpenAI API (С /v1 на конце). По умолчанию https://api.openai.com/v1.
# Для заблокированного хоста — адрес релея, напр. https://<домен-релея>/v1.
OPENAI_BASE_URL=""

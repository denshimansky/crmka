# PostgreSQL — POSTGRES_PASSWORD обязателен (docker-compose упадёт если пусто)
POSTGRES_DB=crmka
POSTGRES_USER=crmka
POSTGRES_PASSWORD=change-me-strong-password

# App
# DATABASE_URL должна совпадать по password/user/db с POSTGRES_* выше
DATABASE_URL="postgresql://crmka:change-me-strong-password@db:5432/crmka?schema=public"
NEXTAUTH_URL="https://dev.umnayacrm.ru"
# Генерация: `openssl rand -hex 32` — обязательно ≥32 символов, иначе app падает в production
NEXTAUTH_SECRET="change-me-to-random-64-char-string"
NODE_ENV=production

# Telegram alerts (для деплоя + бэкапов)
# Бот: BotFather → /newbot. Chat ID: написать боту, открыть https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

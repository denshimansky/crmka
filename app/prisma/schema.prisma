generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// === АВТОРИЗАЦИЯ (NextAuth) ===

model Account {
  id                String  @id @default(uuid()) @db.Uuid
  userId            String  @map("user_id") @db.Uuid
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id") @db.Uuid
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id            String    @id @default(uuid()) @db.Uuid
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  name          String?
  image         String?

  // Связь с сотрудником (и через него — с организацией)
  employeeId String?   @unique @map("employee_id") @db.Uuid
  employee   Employee? @relation(fields: [employeeId], references: [id])

  accounts Account[]
  sessions Session[]

  @@map("users")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// === МУЛЬТИТЕНАНТ ===

model Organization {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  legalName String?  @map("legal_name")
  inn       String?
  phone     String?
  email     String?

  // Настройки
  salaryDay1         Int?     @default(15) @map("salary_day_1")
  salaryDay2         Int?     @default(30) @map("salary_day_2")
  payForAbsence      Boolean  @default(false) @map("pay_for_absence")
  attendanceDeadline Int      @default(14) @map("attendance_deadline")
  debtLimit          Decimal? @db.Decimal(12, 2) @map("debt_limit")
  makeupDaysLimit    Int?     @map("makeup_days_limit")
  makeupDeadlineDays Int?     @map("makeup_deadline_days")
  roleDisplayNames   Json?    @map("role_display_names")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  branches   Branch[]
  employees  Employee[]
  directions Direction[]
  clients    Client[]
  groups     Group[]
  financialAccounts FinancialAccount[]

  @@map("organizations")
}

model Branch {
  id                String    @id @default(uuid()) @db.Uuid
  tenantId          String    @map("tenant_id") @db.Uuid
  name              String
  address           String?
  workingHoursStart String?   @map("working_hours_start")
  workingHoursEnd   String?   @map("working_hours_end")
  workingDays       Json?     @map("working_days")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")

  organization     Organization     @relation(fields: [tenantId], references: [id])
  rooms            Room[]
  employeeBranches EmployeeBranch[]
  clients          Client[]
  groups           Group[]
  financialAccounts FinancialAccount[]

  @@index([tenantId])
  @@map("branches")
}

model Room {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  branchId  String    @map("branch_id") @db.Uuid
  name      String
  capacity  Int       @default(15)
  createdAt DateTime  @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")

  branch Branch @relation(fields: [branchId], references: [id])
  groups Group[]

  @@index([tenantId])
  @@map("rooms")
}

model Employee {
  id               String    @id @default(uuid()) @db.Uuid
  tenantId         String    @map("tenant_id") @db.Uuid
  login            String
  passwordHash     String    @map("password_hash")
  email            String?
  firstName        String    @map("first_name")
  lastName         String    @map("last_name")
  middleName       String?   @map("middle_name")
  phone            String?
  birthDate        DateTime? @map("birth_date") @db.Date
  role             Role
  customPermissions Json?    @map("custom_permissions")
  isActive         Boolean   @default(true) @map("is_active")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  organization     Organization     @relation(fields: [tenantId], references: [id])
  user             User?
  employeeBranches EmployeeBranch[]
  salaryRates      SalaryRate[]
  assignedClients  Client[]         @relation("AssignedClients")
  instructorGroups Group[]          @relation("GroupInstructor")
  instructorLessons Lesson[]        @relation("LessonInstructor")

  @@unique([tenantId, login])
  @@index([tenantId])
  @@map("employees")
}

// === КЛИЕНТЫ ===

model Client {
  id                     String             @id @default(uuid()) @db.Uuid
  tenantId               String             @map("tenant_id") @db.Uuid
  firstName              String?            @map("first_name")
  lastName               String?            @map("last_name")
  patronymic             String?
  phone                  String?
  phone2                 String?
  email                  String?
  socialLink             String?            @map("social_link")
  funnelStatus           FunnelStatus       @default(new) @map("funnel_status")
  clientStatus           ClientWorkStatus?  @map("client_status")
  segment                ClientSegment      @default(new_client) @map("segment")
  totalSubscriptionsCount Int               @default(0) @map("total_subscriptions_count")
  channelId              String?            @map("channel_id") @db.Uuid
  assignedTo             String?            @map("assigned_to") @db.Uuid
  branchId               String?            @map("branch_id") @db.Uuid
  nextContactDate        DateTime?          @map("next_contact_date") @db.Date
  blacklistReason        String?            @map("blacklist_reason")
  blacklistedBy          String?            @map("blacklisted_by") @db.Uuid
  withdrawalReasonId     String?            @map("withdrawal_reason_id") @db.Uuid
  withdrawalDate         DateTime?          @map("withdrawal_date") @db.Date
  clientBalance          Decimal            @default(0) @db.Decimal(12, 2) @map("client_balance")
  promisedPaymentDate    DateTime?          @map("promised_payment_date") @db.Date
  firstPaymentDate       DateTime?          @map("first_payment_date") @db.Date
  firstPaidLessonDate    DateTime?          @map("first_paid_lesson_date") @db.Date
  saleDate               DateTime?          @map("sale_date") @db.Date
  moneyLtv               Decimal            @default(0) @db.Decimal(12, 2) @map("money_ltv")
  monthsLtv              Int                @default(0) @map("months_ltv")
  comment                String?
  createdBy              String?            @map("created_by") @db.Uuid
  createdAt              DateTime           @default(now()) @map("created_at")
  updatedAt              DateTime           @updatedAt @map("updated_at")
  deletedAt              DateTime?          @map("deleted_at")

  organization  Organization       @relation(fields: [tenantId], references: [id])
  branch        Branch?             @relation(fields: [branchId], references: [id])
  assignee      Employee?           @relation("AssignedClients", fields: [assignedTo], references: [id])
  wards         Ward[]
  enrollments   GroupEnrollment[]
  subscriptions Subscription[]
  payments      Payment[]
  attendances   Attendance[]

  @@index([tenantId, funnelStatus])
  @@index([tenantId, clientStatus])
  @@index([tenantId, phone])
  @@map("clients")
}

model Ward {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  clientId  String    @map("client_id") @db.Uuid
  firstName String    @map("first_name")
  lastName  String?   @map("last_name")
  birthDate DateTime? @map("birth_date") @db.Date
  notes     String?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  client        Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  enrollments   GroupEnrollment[]
  subscriptions Subscription[]

  @@index([tenantId])
  @@map("wards")
}

// === НАПРАВЛЕНИЯ ===

model Direction {
  id           String    @id @default(uuid()) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  name         String
  lessonPrice  Decimal   @db.Decimal(12, 2) @map("lesson_price")
  lessonDuration Int     @default(45) @map("lesson_duration")
  trialPrice   Decimal?  @db.Decimal(12, 2) @map("trial_price")
  trialFree    Boolean   @default(false) @map("trial_free")
  color        String?
  sortOrder    Int       @default(0) @map("sort_order")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  organization  Organization   @relation(fields: [tenantId], references: [id])
  salaryRates   SalaryRate[]
  groups        Group[]
  subscriptions Subscription[]

  @@index([tenantId])
  @@map("directions")
}

// === ГРУППЫ И РАСПИСАНИЕ ===

model Group {
  id           String    @id @default(uuid()) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  name         String
  directionId  String    @map("direction_id") @db.Uuid
  branchId     String    @map("branch_id") @db.Uuid
  roomId       String    @map("room_id") @db.Uuid
  instructorId String    @map("instructor_id") @db.Uuid
  maxStudents  Int       @default(15) @map("max_students")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  organization Organization          @relation(fields: [tenantId], references: [id])
  direction    Direction              @relation(fields: [directionId], references: [id])
  branch       Branch                 @relation(fields: [branchId], references: [id])
  room         Room                   @relation(fields: [roomId], references: [id])
  instructor   Employee               @relation("GroupInstructor", fields: [instructorId], references: [id])
  templates     GroupScheduleTemplate[]
  lessons       Lesson[]
  enrollments   GroupEnrollment[]
  subscriptions Subscription[]

  @@index([tenantId])
  @@index([tenantId, branchId])
  @@map("groups")
}

model GroupScheduleTemplate {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  groupId         String    @map("group_id") @db.Uuid
  dayOfWeek       Int       @map("day_of_week")
  startTime       String    @map("start_time")
  durationMinutes Int       @map("duration_minutes")
  effectiveFrom   DateTime  @map("effective_from") @db.Date
  effectiveTo     DateTime? @map("effective_to") @db.Date
  createdAt       DateTime  @default(now()) @map("created_at")

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId])
  @@map("group_schedule_templates")
}

model Lesson {
  id              String       @id @default(uuid()) @db.Uuid
  tenantId        String       @map("tenant_id") @db.Uuid
  groupId         String       @map("group_id") @db.Uuid
  date            DateTime     @db.Date
  startTime       String       @map("start_time")
  durationMinutes Int          @map("duration_minutes")
  instructorId    String       @map("instructor_id") @db.Uuid
  isTrial         Boolean      @default(false) @map("is_trial")
  status          LessonStatus @default(scheduled)
  cancelReason    String?      @map("cancel_reason")
  isMakeup        Boolean      @default(false) @map("is_makeup")
  topic           String?
  homework        String?
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  group       Group        @relation(fields: [groupId], references: [id])
  instructor  Employee     @relation("LessonInstructor", fields: [instructorId], references: [id])
  attendances Attendance[]

  @@index([tenantId, date])
  @@index([groupId, date])
  @@map("lessons")
}

model GroupEnrollment {
  id             String                  @id @default(uuid()) @db.Uuid
  tenantId       String                  @map("tenant_id") @db.Uuid
  groupId        String                  @map("group_id") @db.Uuid
  clientId       String                  @map("client_id") @db.Uuid
  wardId         String?                 @map("ward_id") @db.Uuid
  selectedDays   Json?                   @map("selected_days")
  enrolledAt     DateTime                @map("enrolled_at") @db.Date
  withdrawnAt    DateTime?               @map("withdrawn_at") @db.Date
  paymentStatus  EnrollmentPaymentStatus @default(active) @map("payment_status")
  isActive       Boolean                 @default(true) @map("is_active")
  createdAt      DateTime                @default(now()) @map("created_at")
  updatedAt      DateTime                @updatedAt @map("updated_at")
  deletedAt      DateTime?               @map("deleted_at")

  group  Group   @relation(fields: [groupId], references: [id])
  client Client  @relation(fields: [clientId], references: [id])
  ward   Ward?   @relation(fields: [wardId], references: [id])

  @@index([tenantId])
  @@index([groupId, isActive])
  @@map("group_enrollments")
}

model AttendanceType {
  id                  String   @id @default(uuid()) @db.Uuid
  tenantId            String?  @map("tenant_id") @db.Uuid
  name                String
  code                String
  chargesSubscription Boolean  @default(true) @map("charges_subscription")
  paysInstructor      Boolean  @default(true) @map("pays_instructor")
  countsAsRevenue     Boolean  @default(true) @map("counts_as_revenue")
  isSystem            Boolean  @default(false) @map("is_system")
  isActive            Boolean  @default(true) @map("is_active")
  sortOrder           Int      @default(0) @map("sort_order")
  createdAt           DateTime @default(now()) @map("created_at")

  attendances Attendance[]

  @@index([tenantId])
  @@map("attendance_types")
}

// === ПРИВЯЗКА СОТРУДНИКА К ФИЛИАЛАМ ===

model EmployeeBranch {
  id         String @id @default(uuid()) @db.Uuid
  employeeId String @map("employee_id") @db.Uuid
  branchId   String @map("branch_id") @db.Uuid

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  branch   Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([employeeId, branchId])
  @@map("employee_branches")
}

// === СТАВКИ ЗП ===

model SalaryRate {
  id           String      @id @default(uuid()) @db.Uuid
  tenantId     String      @map("tenant_id") @db.Uuid
  employeeId   String      @map("employee_id") @db.Uuid
  directionId  String?     @map("direction_id") @db.Uuid
  scheme       SalaryScheme
  ratePerStudent Decimal?  @db.Decimal(12, 2) @map("rate_per_student")
  ratePerLesson  Decimal?  @db.Decimal(12, 2) @map("rate_per_lesson")
  fixedPerShift  Decimal?  @db.Decimal(12, 2) @map("fixed_per_shift")
  createdAt    DateTime    @default(now()) @map("created_at")

  employee  Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  direction Direction? @relation(fields: [directionId], references: [id])

  @@index([tenantId])
  @@map("salary_rates")
}

// === АБОНЕМЕНТЫ ===

model Subscription {
  id                     String             @id @default(uuid()) @db.Uuid
  tenantId               String             @map("tenant_id") @db.Uuid
  clientId               String             @map("client_id") @db.Uuid
  wardId                 String?            @map("ward_id") @db.Uuid
  directionId            String             @map("direction_id") @db.Uuid
  groupId                String             @map("group_id") @db.Uuid
  type                   SubscriptionType   @default(calendar)
  status                 SubscriptionStatus @default(pending)
  periodYear             Int                @map("period_year")
  periodMonth            Int                @map("period_month")
  lessonPrice            Decimal            @db.Decimal(12, 2) @map("lesson_price")
  totalLessons           Int                @map("total_lessons")
  totalAmount            Decimal            @db.Decimal(12, 2) @map("total_amount")
  discountAmount         Decimal            @default(0) @db.Decimal(12, 2) @map("discount_amount")
  finalAmount            Decimal            @db.Decimal(12, 2) @map("final_amount")
  balance                Decimal            @default(0) @db.Decimal(12, 2)
  chargedAmount          Decimal            @default(0) @db.Decimal(12, 2) @map("charged_amount")
  startDate              DateTime           @map("start_date") @db.Date
  endDate                DateTime?          @map("end_date") @db.Date
  withdrawalReasonId     String?            @map("withdrawal_reason_id") @db.Uuid
  withdrawalDate         DateTime?          @map("withdrawal_date") @db.Date
  isTrialCredited        Boolean            @default(false) @map("is_trial_credited")
  previousSubscriptionId String?            @map("previous_subscription_id") @db.Uuid
  activatedAt            DateTime?          @map("activated_at")
  createdBy              String?            @map("created_by") @db.Uuid
  createdAt              DateTime           @default(now()) @map("created_at")
  updatedAt              DateTime           @updatedAt @map("updated_at")
  deletedAt              DateTime?          @map("deleted_at")

  client      Client       @relation(fields: [clientId], references: [id])
  ward        Ward?        @relation(fields: [wardId], references: [id])
  direction   Direction    @relation(fields: [directionId], references: [id])
  group       Group        @relation(fields: [groupId], references: [id])
  payments    Payment[]
  discounts   Discount[]
  attendances Attendance[]

  @@index([tenantId, clientId])
  @@index([tenantId, periodYear, periodMonth])
  @@map("subscriptions")
}

// === СЧЕТА (КОШЕЛЬКИ) ===

model FinancialAccount {
  id        String      @id @default(uuid()) @db.Uuid
  tenantId  String      @map("tenant_id") @db.Uuid
  name      String
  type      AccountType
  branchId  String?     @map("branch_id") @db.Uuid
  balance   Decimal     @default(0) @db.Decimal(12, 2)
  isActive  Boolean     @default(true) @map("is_active")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")
  deletedAt DateTime?   @map("deleted_at")

  organization Organization @relation(fields: [tenantId], references: [id])
  branch       Branch?      @relation(fields: [branchId], references: [id])
  payments     Payment[]

  @@index([tenantId])
  @@map("financial_accounts")
}

// === ОПЛАТЫ ===

model Payment {
  id               String        @id @default(uuid()) @db.Uuid
  tenantId         String        @map("tenant_id") @db.Uuid
  clientId         String        @map("client_id") @db.Uuid
  subscriptionId   String?       @map("subscription_id") @db.Uuid
  accountId        String        @map("account_id") @db.Uuid
  amount           Decimal       @db.Decimal(12, 2)
  type             PaymentType   @default(incoming)
  method           PaymentMethod
  date             DateTime      @db.Date
  comment          String?
  isFirstPayment   Boolean       @default(false) @map("is_first_payment")
  onlinePaymentId  String?       @map("online_payment_id")
  createdBy        String?       @map("created_by") @db.Uuid
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")
  deletedAt        DateTime?     @map("deleted_at")

  client       Client        @relation(fields: [clientId], references: [id])
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])
  account      FinancialAccount @relation(fields: [accountId], references: [id])

  @@index([tenantId, date])
  @@index([tenantId, clientId])
  @@map("payments")
}

// === СКИДКИ ===

model Discount {
  id                   String            @id @default(uuid()) @db.Uuid
  tenantId             String            @map("tenant_id") @db.Uuid
  subscriptionId       String            @map("subscription_id") @db.Uuid
  type                 DiscountType
  valueType            DiscountValueType @map("value_type")
  value                Decimal           @db.Decimal(12, 2)
  calculatedAmount     Decimal           @db.Decimal(12, 2) @map("calculated_amount")
  linkedClientId       String?           @map("linked_client_id") @db.Uuid
  comment              String?
  startDate            DateTime          @map("start_date") @db.Date
  endDate              DateTime?         @map("end_date") @db.Date
  isActive             Boolean           @default(true) @map("is_active")
  createdBy            String?           @map("created_by") @db.Uuid
  createdAt            DateTime          @default(now()) @map("created_at")

  subscription Subscription @relation(fields: [subscriptionId], references: [id])

  @@index([tenantId])
  @@map("discounts")
}

// === ПОСЕЩЕНИЯ ===

model Attendance {
  id                  String   @id @default(uuid()) @db.Uuid
  tenantId            String   @map("tenant_id") @db.Uuid
  lessonId            String   @map("lesson_id") @db.Uuid
  subscriptionId      String?  @map("subscription_id") @db.Uuid
  clientId            String   @map("client_id") @db.Uuid
  wardId              String?  @map("ward_id") @db.Uuid
  attendanceTypeId    String   @map("attendance_type_id") @db.Uuid
  absenceReasonId     String?  @map("absence_reason_id") @db.Uuid
  chargeAmount        Decimal  @default(0) @db.Decimal(12, 2) @map("charge_amount")
  instructorPayAmount Decimal  @default(0) @db.Decimal(12, 2) @map("instructor_pay_amount")
  instructorPayEnabled Boolean @default(true) @map("instructor_pay_enabled")
  isTrial             Boolean  @default(false) @map("is_trial")
  markedBy            String?  @map("marked_by") @db.Uuid
  markedAt            DateTime? @map("marked_at")
  isAfterPeriodClose  Boolean  @default(false) @map("is_after_period_close")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  lesson         Lesson         @relation(fields: [lessonId], references: [id])
  subscription   Subscription?  @relation(fields: [subscriptionId], references: [id])
  client         Client         @relation(fields: [clientId], references: [id])
  attendanceType AttendanceType @relation(fields: [attendanceTypeId], references: [id])

  @@unique([lessonId, subscriptionId])
  @@index([tenantId, lessonId])
  @@map("attendances")
}

// === ЛОГ АУДИТА ===

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  employeeId String   @map("employee_id") @db.Uuid
  action     String
  entity     String
  entityId   String?  @map("entity_id")
  details    Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([tenantId, createdAt])
  @@map("audit_logs")
}

// === ENUMS ===

enum Role {
  owner
  manager
  admin
  instructor
  readonly
}

enum SalaryScheme {
  per_student
  per_lesson
  fixed_plus_per_student
}

enum FunnelStatus {
  new
  trial_scheduled
  trial_attended
  awaiting_payment
  active_client
  potential
  non_target
  blacklisted
  archived
}

enum ClientWorkStatus {
  active
  upsell
  churned
  returning
  archived
}

enum ClientSegment {
  new_client
  standard
  regular
  vip
}

enum LessonStatus {
  scheduled
  completed
  cancelled
}

enum SubscriptionType {
  calendar
  fixed
  package
}

enum SubscriptionStatus {
  pending
  active
  closed
  withdrawn
}

enum AccountType {
  cash
  bank_account
  acquiring
  online
}

enum PaymentType {
  incoming
  refund
  transfer_in
}

enum PaymentMethod {
  cash
  bank_transfer
  acquiring
  online_yukassa
  online_robokassa
  sbp_qr
}

enum DiscountType {
  permanent
  one_time
  linked
}

enum DiscountValueType {
  percent
  fixed
}

enum EnrollmentPaymentStatus {
  active
  awaiting_payment
  trial
}

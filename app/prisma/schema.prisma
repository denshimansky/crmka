generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// === АВТОРИЗАЦИЯ (NextAuth) ===

model Account {
  id                String  @id @default(uuid()) @db.Uuid
  userId            String  @map("user_id") @db.Uuid
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id") @db.Uuid
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id            String    @id @default(uuid()) @db.Uuid
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  name          String?
  image         String?

  // Связь с сотрудником (и через него — с организацией)
  employeeId String?   @unique @map("employee_id") @db.Uuid
  employee   Employee? @relation(fields: [employeeId], references: [id])

  accounts Account[]
  sessions Session[]

  @@map("users")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// === МУЛЬТИТЕНАНТ ===

model Organization {
  id        String  @id @default(uuid()) @db.Uuid
  name      String
  legalName String? @map("legal_name")
  inn       String?
  phone     String?
  email     String?

  // Настройки
  salaryDay1         Int?     @default(15) @map("salary_day_1")
  salaryDay2         Int?     @default(30) @map("salary_day_2")
  payForAbsence      Boolean  @default(false) @map("pay_for_absence")
  attendanceDeadline Int      @default(14) @map("attendance_deadline")
  debtLimit          Decimal? @map("debt_limit") @db.Decimal(12, 2)
  makeupDaysLimit    Int?     @map("makeup_days_limit")
  makeupDeadlineDays Int?     @map("makeup_deadline_days")
  roleDisplayNames   Json?    @map("role_display_names")

  // Биллинг
  billingStatus BillingStatus @default(active) @map("billing_status")
  contactPerson String?       @map("contact_person")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  branches                  Branch[]
  employees                 Employee[]
  directions                Direction[]
  clients                   Client[]
  groups                    Group[]
  financialAccounts         FinancialAccount[]
  billingSubscriptions      BillingSubscription[]
  billingInvoices           BillingInvoice[]
  periods                   Period[]
  auditLogs                 AuditLog[]
  trialLessons              TrialLesson[]
  clientBalanceTransactions ClientBalanceTransaction[]
  productionCalendar        ProductionCalendar[]
  discountTemplates         DiscountTemplate[]
  plannedExpenses           PlannedExpense[]
  adminBonusSettings        AdminBonusSettings[]
  notifications             Notification[]
  unprolongedComments       UnprolongedComment[]
  employeeBranches          EmployeeBranch[]

  @@map("organizations")
}

model Branch {
  id                String    @id @default(uuid()) @db.Uuid
  tenantId          String    @map("tenant_id") @db.Uuid
  name              String
  address           String?
  workingHoursStart String?   @map("working_hours_start")
  workingHoursEnd   String?   @map("working_hours_end")
  workingDays       Json?     @map("working_days")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")

  organization       Organization         @relation(fields: [tenantId], references: [id])
  rooms              Room[]
  employeeBranches   EmployeeBranch[]
  clients            Client[]
  groups             Group[]
  financialAccounts  FinancialAccount[]
  expenseBranches    ExpenseBranch[]
  plannedExpenses    PlannedExpense[]
  adminBonusSettings AdminBonusSettings[]

  @@index([tenantId])
  @@map("branches")
}

model Room {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  branchId  String    @map("branch_id") @db.Uuid
  name      String
  capacity  Int       @default(15)
  createdAt DateTime  @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")

  branch Branch  @relation(fields: [branchId], references: [id])
  groups Group[]

  @@index([tenantId])
  @@map("rooms")
}

model Employee {
  id                String    @id @default(uuid()) @db.Uuid
  tenantId          String    @map("tenant_id") @db.Uuid
  login             String
  passwordHash      String    @map("password_hash")
  email             String?
  firstName         String    @map("first_name")
  lastName          String    @map("last_name")
  middleName        String?   @map("middle_name")
  phone             String?
  birthDate         DateTime? @map("birth_date") @db.Date
  role              Role
  customPermissions Json?     @map("custom_permissions")
  isActive          Boolean   @default(true) @map("is_active")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")

  organization               Organization         @relation(fields: [tenantId], references: [id])
  user                       User?
  employeeBranches           EmployeeBranch[]
  salaryRates                SalaryRate[]
  salaryPayments             SalaryPayment[]
  salaryAdjustments          SalaryAdjustment[]
  assignedClients            Client[]             @relation("AssignedClients")
  assignedTasks              Task[]               @relation("TaskAssignee")
  instructorGroups           Group[]              @relation("GroupInstructor")
  instructorLessons          Lesson[]             @relation("LessonInstructor")
  periodsClosed              Period[]             @relation("periodClosedBy")
  periodsReopened            Period[]             @relation("periodReopenedBy")
  auditLogs                  AuditLog[]
  plannedExpenses            PlannedExpense[]     @relation("PlannedExpenseEmployee")
  adminBonusSettings         AdminBonusSettings[]
  notifications              Notification[]
  unprolongedCommentsCreated UnprolongedComment[] @relation("UnprolongedCommentCreator")

  @@unique([tenantId, login])
  @@index([tenantId])
  @@map("employees")
}

// === КЛИЕНТЫ ===

model Client {
  id                      String            @id @default(uuid()) @db.Uuid
  tenantId                String            @map("tenant_id") @db.Uuid
  firstName               String?           @map("first_name")
  lastName                String?           @map("last_name")
  patronymic              String?
  phone                   String?
  phone2                  String?
  email                   String?
  socialLink              String?           @map("social_link")
  funnelStatus            FunnelStatus      @default(new) @map("funnel_status")
  clientStatus            ClientWorkStatus? @map("client_status")
  segment                 ClientSegment     @default(new_client) @map("segment")
  totalSubscriptionsCount Int               @default(0) @map("total_subscriptions_count")
  channelId               String?           @map("channel_id") @db.Uuid
  assignedTo              String?           @map("assigned_to") @db.Uuid
  branchId                String?           @map("branch_id") @db.Uuid
  nextContactDate         DateTime?         @map("next_contact_date") @db.Date
  blacklistReason         String?           @map("blacklist_reason")
  blacklistedBy           String?           @map("blacklisted_by") @db.Uuid
  withdrawalReasonId      String?           @map("withdrawal_reason_id") @db.Uuid
  withdrawalDate          DateTime?         @map("withdrawal_date") @db.Date
  clientBalance           Decimal           @default(0) @map("client_balance") @db.Decimal(12, 2)
  promisedPaymentDate     DateTime?         @map("promised_payment_date") @db.Date
  firstPaymentDate        DateTime?         @map("first_payment_date") @db.Date
  firstPaidLessonDate     DateTime?         @map("first_paid_lesson_date") @db.Date
  saleDate                DateTime?         @map("sale_date") @db.Date
  moneyLtv                Decimal           @default(0) @map("money_ltv") @db.Decimal(12, 2)
  monthsLtv               Int               @default(0) @map("months_ltv")
  comment                 String?
  createdBy               String?           @map("created_by") @db.Uuid
  createdAt               DateTime          @default(now()) @map("created_at")
  updatedAt               DateTime          @updatedAt @map("updated_at")
  deletedAt               DateTime?         @map("deleted_at")

  organization        Organization               @relation(fields: [tenantId], references: [id])
  branch              Branch?                    @relation(fields: [branchId], references: [id])
  assignee            Employee?                  @relation("AssignedClients", fields: [assignedTo], references: [id])
  wards               Ward[]
  enrollments         GroupEnrollment[]
  subscriptions       Subscription[]
  payments            Payment[]
  attendances         Attendance[]
  tasks               Task[]
  callCampaignItems   CallCampaignItem[]
  portalTokens        ClientPortalToken[]
  trialLessons        TrialLesson[]
  balanceTransactions ClientBalanceTransaction[]
  unprolongedComments UnprolongedComment[]

  @@index([tenantId, funnelStatus])
  @@index([tenantId, clientStatus])
  @@index([tenantId, phone])
  @@map("clients")
}

model Ward {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  clientId  String    @map("client_id") @db.Uuid
  firstName String    @map("first_name")
  lastName  String?   @map("last_name")
  birthDate DateTime? @map("birth_date") @db.Date
  notes     String?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  client        Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  enrollments   GroupEnrollment[]
  subscriptions Subscription[]
  trialLessons  TrialLesson[]

  @@index([tenantId])
  @@map("wards")
}

// === НАПРАВЛЕНИЯ ===

model Direction {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  name           String
  lessonPrice    Decimal   @map("lesson_price") @db.Decimal(12, 2)
  lessonDuration Int       @default(45) @map("lesson_duration")
  trialPrice     Decimal?  @map("trial_price") @db.Decimal(12, 2)
  trialFree      Boolean   @default(false) @map("trial_free")
  color          String?
  sortOrder      Int       @default(0) @map("sort_order")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  organization    Organization    @relation(fields: [tenantId], references: [id])
  salaryRates     SalaryRate[]
  groups          Group[]
  subscriptions   Subscription[]
  expenseBranches ExpenseBranch[]

  @@index([tenantId])
  @@map("directions")
}

// === ГРУППЫ И РАСПИСАНИЕ ===

model Group {
  id           String    @id @default(uuid()) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  name         String
  directionId  String    @map("direction_id") @db.Uuid
  branchId     String    @map("branch_id") @db.Uuid
  roomId       String    @map("room_id") @db.Uuid
  instructorId String    @map("instructor_id") @db.Uuid
  maxStudents  Int       @default(15) @map("max_students")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  organization  Organization            @relation(fields: [tenantId], references: [id])
  direction     Direction               @relation(fields: [directionId], references: [id])
  branch        Branch                  @relation(fields: [branchId], references: [id])
  room          Room                    @relation(fields: [roomId], references: [id])
  instructor    Employee                @relation("GroupInstructor", fields: [instructorId], references: [id])
  templates     GroupScheduleTemplate[]
  lessons       Lesson[]
  enrollments   GroupEnrollment[]
  subscriptions Subscription[]
  trialLessons  TrialLesson[]

  @@index([tenantId])
  @@index([tenantId, branchId])
  @@map("groups")
}

model GroupScheduleTemplate {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  groupId         String    @map("group_id") @db.Uuid
  dayOfWeek       Int       @map("day_of_week")
  startTime       String    @map("start_time")
  durationMinutes Int       @map("duration_minutes")
  effectiveFrom   DateTime  @map("effective_from") @db.Date
  effectiveTo     DateTime? @map("effective_to") @db.Date
  createdAt       DateTime  @default(now()) @map("created_at")

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId])
  @@map("group_schedule_templates")
}

model Lesson {
  id              String       @id @default(uuid()) @db.Uuid
  tenantId        String       @map("tenant_id") @db.Uuid
  groupId         String       @map("group_id") @db.Uuid
  date            DateTime     @db.Date
  startTime       String       @map("start_time")
  durationMinutes Int          @map("duration_minutes")
  instructorId    String       @map("instructor_id") @db.Uuid
  isTrial         Boolean      @default(false) @map("is_trial")
  status          LessonStatus @default(scheduled)
  cancelReason    String?      @map("cancel_reason")
  isMakeup        Boolean      @default(false) @map("is_makeup")
  topic           String?
  homework        String?
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  group        Group         @relation(fields: [groupId], references: [id])
  instructor   Employee      @relation("LessonInstructor", fields: [instructorId], references: [id])
  attendances  Attendance[]
  trialLessons TrialLesson[]

  @@index([tenantId, date])
  @@index([groupId, date])
  @@map("lessons")
}

model GroupEnrollment {
  id            String                  @id @default(uuid()) @db.Uuid
  tenantId      String                  @map("tenant_id") @db.Uuid
  groupId       String                  @map("group_id") @db.Uuid
  clientId      String                  @map("client_id") @db.Uuid
  wardId        String?                 @map("ward_id") @db.Uuid
  selectedDays  Json?                   @map("selected_days")
  enrolledAt    DateTime                @map("enrolled_at") @db.Date
  withdrawnAt   DateTime?               @map("withdrawn_at") @db.Date
  paymentStatus EnrollmentPaymentStatus @default(active) @map("payment_status")
  isActive      Boolean                 @default(true) @map("is_active")
  createdAt     DateTime                @default(now()) @map("created_at")
  updatedAt     DateTime                @updatedAt @map("updated_at")
  deletedAt     DateTime?               @map("deleted_at")

  group  Group  @relation(fields: [groupId], references: [id])
  client Client @relation(fields: [clientId], references: [id])
  ward   Ward?  @relation(fields: [wardId], references: [id])

  @@index([tenantId])
  @@index([groupId, isActive])
  @@map("group_enrollments")
}

model AttendanceType {
  id                  String   @id @default(uuid()) @db.Uuid
  tenantId            String?  @map("tenant_id") @db.Uuid
  name                String
  code                String
  chargesSubscription Boolean  @default(true) @map("charges_subscription")
  paysInstructor      Boolean  @default(true) @map("pays_instructor")
  countsAsRevenue     Boolean  @default(true) @map("counts_as_revenue")
  isSystem            Boolean  @default(false) @map("is_system")
  isActive            Boolean  @default(true) @map("is_active")
  sortOrder           Int      @default(0) @map("sort_order")
  createdAt           DateTime @default(now()) @map("created_at")

  attendances Attendance[]

  @@index([tenantId])
  @@map("attendance_types")
}

// === ПРИВЯЗКА СОТРУДНИКА К ФИЛИАЛАМ ===

model EmployeeBranch {
  id         String @id @default(uuid()) @db.Uuid
  tenantId   String @map("tenant_id") @db.Uuid
  employeeId String @map("employee_id") @db.Uuid
  branchId   String @map("branch_id") @db.Uuid

  organization Organization @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  branch       Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([tenantId, employeeId, branchId])
  @@map("employee_branches")
}

// === СТАВКИ ЗП ===

model SalaryRate {
  id             String       @id @default(uuid()) @db.Uuid
  tenantId       String       @map("tenant_id") @db.Uuid
  employeeId     String       @map("employee_id") @db.Uuid
  directionId    String?      @map("direction_id") @db.Uuid
  scheme         SalaryScheme
  ratePerStudent Decimal?     @map("rate_per_student") @db.Decimal(12, 2)
  ratePerLesson  Decimal?     @map("rate_per_lesson") @db.Decimal(12, 2)
  fixedPerShift  Decimal?     @map("fixed_per_shift") @db.Decimal(12, 2)
  createdAt      DateTime     @default(now()) @map("created_at")

  employee  Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  direction Direction? @relation(fields: [directionId], references: [id])

  @@index([tenantId])
  @@map("salary_rates")
}

// === ВЫПЛАТЫ ЗП ===

model SalaryPayment {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  employeeId  String   @map("employee_id") @db.Uuid
  accountId   String   @map("account_id") @db.Uuid
  amount      Decimal  @db.Decimal(12, 2)
  date        DateTime @db.Date
  periodYear  Int      @map("period_year")
  periodMonth Int      @map("period_month")
  periodHalf  Int?     @map("period_half")
  comment     String?
  createdBy   String?  @map("created_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  employee Employee         @relation(fields: [employeeId], references: [id])
  account  FinancialAccount @relation(fields: [accountId], references: [id])

  @@index([tenantId, periodYear, periodMonth])
  @@map("salary_payments")
}

model SalaryAdjustment {
  id          String         @id @default(uuid()) @db.Uuid
  tenantId    String         @map("tenant_id") @db.Uuid
  employeeId  String         @map("employee_id") @db.Uuid
  type        AdjustmentType
  amount      Decimal        @db.Decimal(12, 2)
  periodYear  Int            @map("period_year")
  periodMonth Int            @map("period_month")
  comment     String
  createdBy   String?        @map("created_by") @db.Uuid
  createdAt   DateTime       @default(now()) @map("created_at")

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([tenantId, periodYear, periodMonth])
  @@map("salary_adjustments")
}

// === АБОНЕМЕНТЫ ===

model Subscription {
  id                     String             @id @default(uuid()) @db.Uuid
  tenantId               String             @map("tenant_id") @db.Uuid
  clientId               String             @map("client_id") @db.Uuid
  wardId                 String?            @map("ward_id") @db.Uuid
  directionId            String             @map("direction_id") @db.Uuid
  groupId                String             @map("group_id") @db.Uuid
  type                   SubscriptionType   @default(calendar)
  status                 SubscriptionStatus @default(pending)
  periodYear             Int                @map("period_year")
  periodMonth            Int                @map("period_month")
  lessonPrice            Decimal            @map("lesson_price") @db.Decimal(12, 2)
  totalLessons           Int                @map("total_lessons")
  totalAmount            Decimal            @map("total_amount") @db.Decimal(12, 2)
  discountAmount         Decimal            @default(0) @map("discount_amount") @db.Decimal(12, 2)
  finalAmount            Decimal            @map("final_amount") @db.Decimal(12, 2)
  balance                Decimal            @default(0) @db.Decimal(12, 2)
  chargedAmount          Decimal            @default(0) @map("charged_amount") @db.Decimal(12, 2)
  startDate              DateTime           @map("start_date") @db.Date
  endDate                DateTime?          @map("end_date") @db.Date
  withdrawalReasonId     String?            @map("withdrawal_reason_id") @db.Uuid
  withdrawalDate         DateTime?          @map("withdrawal_date") @db.Date
  isTrialCredited        Boolean            @default(false) @map("is_trial_credited")
  previousSubscriptionId String?            @map("previous_subscription_id") @db.Uuid
  activatedAt            DateTime?          @map("activated_at")
  createdBy              String?            @map("created_by") @db.Uuid
  createdAt              DateTime           @default(now()) @map("created_at")
  updatedAt              DateTime           @updatedAt @map("updated_at")
  deletedAt              DateTime?          @map("deleted_at")

  client              Client                     @relation(fields: [clientId], references: [id])
  ward                Ward?                      @relation(fields: [wardId], references: [id])
  direction           Direction                  @relation(fields: [directionId], references: [id])
  group               Group                      @relation(fields: [groupId], references: [id])
  payments            Payment[]
  discounts           Discount[]
  attendances         Attendance[]
  balanceTransactions ClientBalanceTransaction[]
  unprolongedComments UnprolongedComment[]

  @@index([tenantId, clientId])
  @@index([tenantId, periodYear, periodMonth])
  @@map("subscriptions")
}

// === СЧЕТА (КОШЕЛЬКИ) ===

model FinancialAccount {
  id        String      @id @default(uuid()) @db.Uuid
  tenantId  String      @map("tenant_id") @db.Uuid
  name      String
  type      AccountType
  branchId  String?     @map("branch_id") @db.Uuid
  balance   Decimal     @default(0) @db.Decimal(12, 2)
  isActive  Boolean     @default(true) @map("is_active")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")
  deletedAt DateTime?   @map("deleted_at")

  organization   Organization       @relation(fields: [tenantId], references: [id])
  branch         Branch?            @relation(fields: [branchId], references: [id])
  payments       Payment[]
  expenses       Expense[]
  salaryPayments SalaryPayment[]
  operationsFrom AccountOperation[] @relation("OperationFrom")
  operationsTo   AccountOperation[] @relation("OperationTo")

  @@index([tenantId])
  @@map("financial_accounts")
}

// === ОПЛАТЫ ===

model Payment {
  id              String        @id @default(uuid()) @db.Uuid
  tenantId        String        @map("tenant_id") @db.Uuid
  clientId        String        @map("client_id") @db.Uuid
  subscriptionId  String?       @map("subscription_id") @db.Uuid
  accountId       String        @map("account_id") @db.Uuid
  amount          Decimal       @db.Decimal(12, 2)
  type            PaymentType   @default(incoming)
  method          PaymentMethod
  date            DateTime      @db.Date
  comment         String?
  isFirstPayment  Boolean       @default(false) @map("is_first_payment")
  onlinePaymentId String?       @map("online_payment_id")
  createdBy       String?       @map("created_by") @db.Uuid
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  deletedAt       DateTime?     @map("deleted_at")

  client              Client                     @relation(fields: [clientId], references: [id])
  subscription        Subscription?              @relation(fields: [subscriptionId], references: [id])
  account             FinancialAccount           @relation(fields: [accountId], references: [id])
  balanceTransactions ClientBalanceTransaction[]

  @@index([tenantId, date])
  @@index([tenantId, clientId])
  @@map("payments")
}

// === СКИДКИ ===

model Discount {
  id               String            @id @default(uuid()) @db.Uuid
  tenantId         String            @map("tenant_id") @db.Uuid
  subscriptionId   String            @map("subscription_id") @db.Uuid
  type             DiscountType
  valueType        DiscountValueType @map("value_type")
  value            Decimal           @db.Decimal(12, 2)
  calculatedAmount Decimal           @map("calculated_amount") @db.Decimal(12, 2)
  linkedClientId   String?           @map("linked_client_id") @db.Uuid
  comment          String?
  startDate        DateTime          @map("start_date") @db.Date
  endDate          DateTime?         @map("end_date") @db.Date
  isActive         Boolean           @default(true) @map("is_active")
  createdBy        String?           @map("created_by") @db.Uuid
  createdAt        DateTime          @default(now()) @map("created_at")

  subscription Subscription @relation(fields: [subscriptionId], references: [id])

  @@index([tenantId])
  @@map("discounts")
}

// === ПОСЕЩЕНИЯ ===

model Attendance {
  id                   String    @id @default(uuid()) @db.Uuid
  tenantId             String    @map("tenant_id") @db.Uuid
  lessonId             String    @map("lesson_id") @db.Uuid
  subscriptionId       String?   @map("subscription_id") @db.Uuid
  clientId             String    @map("client_id") @db.Uuid
  wardId               String?   @map("ward_id") @db.Uuid
  attendanceTypeId     String    @map("attendance_type_id") @db.Uuid
  absenceReasonId      String?   @map("absence_reason_id") @db.Uuid
  chargeAmount         Decimal   @default(0) @map("charge_amount") @db.Decimal(12, 2)
  instructorPayAmount  Decimal   @default(0) @map("instructor_pay_amount") @db.Decimal(12, 2)
  instructorPayEnabled Boolean   @default(true) @map("instructor_pay_enabled")
  isTrial              Boolean   @default(false) @map("is_trial")
  markedBy             String?   @map("marked_by") @db.Uuid
  markedAt             DateTime? @map("marked_at")
  isAfterPeriodClose   Boolean   @default(false) @map("is_after_period_close")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  lesson         Lesson         @relation(fields: [lessonId], references: [id])
  subscription   Subscription?  @relation(fields: [subscriptionId], references: [id])
  client         Client         @relation(fields: [clientId], references: [id])
  attendanceType AttendanceType @relation(fields: [attendanceTypeId], references: [id])

  @@unique([tenantId, lessonId, subscriptionId])
  @@index([tenantId, lessonId])
  @@map("attendances")
}

// === ЗАДАЧИ ===

model Task {
  id          String           @id @default(uuid()) @db.Uuid
  tenantId    String           @map("tenant_id") @db.Uuid
  title       String
  description String?
  type        TaskType
  autoTrigger TaskAutoTrigger? @map("auto_trigger")
  status      TaskStatus       @default(pending)
  dueDate     DateTime         @map("due_date") @db.Date
  assignedTo  String           @map("assigned_to") @db.Uuid
  assignedBy  String?          @map("assigned_by") @db.Uuid
  clientId    String?          @map("client_id") @db.Uuid
  completedAt DateTime?        @map("completed_at")
  completedBy String?          @map("completed_by") @db.Uuid
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  deletedAt   DateTime?        @map("deleted_at")

  assignee Employee @relation("TaskAssignee", fields: [assignedTo], references: [id])
  client   Client?  @relation(fields: [clientId], references: [id])

  @@index([tenantId, status, dueDate])
  @@index([tenantId, assignedTo])
  @@map("tasks")
}

// === ОБЗВОН ===

model CallCampaign {
  id             String             @id @default(uuid()) @db.Uuid
  tenantId       String             @map("tenant_id") @db.Uuid
  name           String
  status         CallCampaignStatus @default(active)
  filterCriteria Json               @map("filter_criteria")
  assignedTo     String?            @map("assigned_to") @db.Uuid
  totalItems     Int                @default(0) @map("total_items")
  completedItems Int                @default(0) @map("completed_items")
  createdBy      String?            @map("created_by") @db.Uuid
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")
  deletedAt      DateTime?          @map("deleted_at")

  items CallCampaignItem[]

  @@index([tenantId])
  @@map("call_campaigns")
}

model CallCampaignItem {
  id         String         @id @default(uuid()) @db.Uuid
  tenantId   String         @map("tenant_id") @db.Uuid
  campaignId String         @map("campaign_id") @db.Uuid
  clientId   String         @map("client_id") @db.Uuid
  status     CallItemStatus @default(pending)
  comment    String?
  result     String?
  calledBy   String?        @map("called_by") @db.Uuid
  calledAt   DateTime?      @map("called_at")
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")

  campaign CallCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  client   Client       @relation(fields: [clientId], references: [id])

  @@index([campaignId])
  @@map("call_campaign_items")
}

// === РАСХОДЫ ===

model ExpenseCategory {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String?  @map("tenant_id") @db.Uuid
  name       String
  isSalary   Boolean  @default(false) @map("is_salary")
  isVariable Boolean  @default(false) @map("is_variable")
  isSystem   Boolean  @default(false) @map("is_system")
  isActive   Boolean  @default(true) @map("is_active")
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")

  expenses        Expense[]
  plannedExpenses PlannedExpense[]

  @@index([tenantId])
  @@map("expense_categories")
}

model Expense {
  id                    String    @id @default(uuid()) @db.Uuid
  tenantId              String    @map("tenant_id") @db.Uuid
  categoryId            String    @map("category_id") @db.Uuid
  accountId             String    @map("account_id") @db.Uuid
  amount                Decimal   @db.Decimal(12, 2)
  date                  DateTime  @db.Date
  comment               String?
  amortizationMonths    Int?      @map("amortization_months")
  amortizationStartDate DateTime? @map("amortization_start_date") @db.Date
  isVariable            Boolean   @default(false) @map("is_variable")
  isRecurring           Boolean   @default(false) @map("is_recurring")
  recurringGroupId      String?   @map("recurring_group_id") @db.Uuid
  createdBy             String?   @map("created_by") @db.Uuid
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  deletedAt             DateTime? @map("deleted_at")

  category ExpenseCategory  @relation(fields: [categoryId], references: [id])
  account  FinancialAccount @relation(fields: [accountId], references: [id])
  branches ExpenseBranch[]

  @@index([tenantId, date])
  @@index([tenantId, categoryId])
  @@map("expenses")
}

model ExpenseBranch {
  id          String  @id @default(uuid()) @db.Uuid
  tenantId    String  @map("tenant_id") @db.Uuid
  expenseId   String  @map("expense_id") @db.Uuid
  branchId    String? @map("branch_id") @db.Uuid
  directionId String? @map("direction_id") @db.Uuid

  expense   Expense    @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  branch    Branch?    @relation(fields: [branchId], references: [id])
  direction Direction? @relation(fields: [directionId], references: [id])

  @@index([expenseId])
  @@map("expense_branches")
}

// === ВНУТРЕННИЕ КАССОВЫЕ ОПЕРАЦИИ ===

model AccountOperation {
  id            String               @id @default(uuid()) @db.Uuid
  tenantId      String               @map("tenant_id") @db.Uuid
  type          AccountOperationType
  fromAccountId String?              @map("from_account_id") @db.Uuid
  toAccountId   String?              @map("to_account_id") @db.Uuid
  amount        Decimal              @db.Decimal(12, 2)
  date          DateTime             @db.Date
  description   String?
  createdBy     String?              @map("created_by") @db.Uuid
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")
  deletedAt     DateTime?            @map("deleted_at")

  fromAccount FinancialAccount? @relation("OperationFrom", fields: [fromAccountId], references: [id])
  toAccount   FinancialAccount? @relation("OperationTo", fields: [toAccountId], references: [id])

  @@index([tenantId, date])
  @@map("account_operations")
}

// === ЛОГ АУДИТА ===

model AuditLog {
  id                 String   @id @default(uuid()) @db.Uuid
  tenantId           String   @map("tenant_id") @db.Uuid
  employeeId         String   @map("employee_id") @db.Uuid
  action             String // create | update | delete
  entityType         String   @map("entity_type") // Attendance, Payment, Expense...
  entityId           String   @map("entity_id") @db.Uuid
  changes            Json? // {field: {old, new}}
  isAfterPeriodClose Boolean  @default(false) @map("is_after_period_close")
  ipAddress          String?  @map("ip_address")
  userAgent          String?  @map("user_agent")
  createdAt          DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [tenantId], references: [id])
  employee     Employee     @relation(fields: [employeeId], references: [id])

  @@index([tenantId, entityType, entityId])
  @@index([tenantId, createdAt])
  @@map("audit_logs")
}


generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// === АВТОРИЗАЦИЯ (NextAuth) ===

model Account {
  id                String  @id @default(uuid()) @db.Uuid
  userId            String  @map("user_id") @db.Uuid
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id") @db.Uuid
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id            String    @id @default(uuid()) @db.Uuid
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  name          String?
  image         String?

  // Связь с сотрудником (и через него — с организацией)
  employeeId String?   @unique @map("employee_id") @db.Uuid
  employee   Employee? @relation(fields: [employeeId], references: [id])

  accounts Account[]
  sessions Session[]

  @@map("users")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// === МУЛЬТИТЕНАНТ ===

model Organization {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  legalName String?  @map("legal_name")
  inn       String?
  phone     String?
  email     String?

  // Настройки
  salaryDay1         Int?     @default(15) @map("salary_day_1")
  salaryDay2         Int?     @default(30) @map("salary_day_2")
  payForAbsence      Boolean  @default(false) @map("pay_for_absence")
  attendanceDeadline Int      @default(14) @map("attendance_deadline")
  debtLimit          Decimal? @db.Decimal(12, 2) @map("debt_limit")
  makeupDaysLimit    Int?     @map("makeup_days_limit")
  makeupDeadlineDays Int?     @map("makeup_deadline_days")
  roleDisplayNames   Json?    @map("role_display_names")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  branches  Branch[]
  employees Employee[]

  @@map("organizations")
}

model Branch {
  id                String    @id @default(uuid()) @db.Uuid
  tenantId          String    @map("tenant_id") @db.Uuid
  name              String
  address           String?
  workingHoursStart String?   @map("working_hours_start")
  workingHoursEnd   String?   @map("working_hours_end")
  workingDays       Json?     @map("working_days")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")

  organization Organization @relation(fields: [tenantId], references: [id])
  rooms        Room[]

  @@index([tenantId])
  @@map("branches")
}

model Room {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  branchId  String    @map("branch_id") @db.Uuid
  name      String
  capacity  Int       @default(15)
  createdAt DateTime  @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")

  branch Branch @relation(fields: [branchId], references: [id])

  @@index([tenantId])
  @@map("rooms")
}

model Employee {
  id               String    @id @default(uuid()) @db.Uuid
  tenantId         String    @map("tenant_id") @db.Uuid
  login            String
  passwordHash     String    @map("password_hash")
  email            String?
  firstName        String    @map("first_name")
  lastName         String    @map("last_name")
  middleName       String?   @map("middle_name")
  phone            String?
  role             Role
  customPermissions Json?    @map("custom_permissions")
  isActive         Boolean   @default(true) @map("is_active")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  organization Organization @relation(fields: [tenantId], references: [id])
  user         User?

  @@unique([tenantId, login])
  @@index([tenantId])
  @@map("employees")
}

enum Role {
  owner
  manager
  admin
  instructor
  readonly
}

// === БИЛЛИНГ (SaaS) ===

// Администраторы бэк-офиса (внутренняя команда CRMka)
model AdminUser {
  id           String    @id @default(uuid()) @db.Uuid
  email        String    @unique
  passwordHash String    @map("password_hash")
  name         String
  role         AdminRole
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@map("admin_users")
}

// Тарифные планы
model BillingPlan {
  id             String   @id @default(uuid()) @db.Uuid
  name           String
  pricePerBranch Decimal  @map("price_per_branch") @db.Decimal(12, 2)
  description    String?
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  subscriptions BillingSubscription[]

  @@map("billing_plans")
}

// Подписки партнёров
model BillingSubscription {
  id              String                    @id @default(uuid()) @db.Uuid
  organizationId  String                    @map("organization_id") @db.Uuid
  planId          String                    @map("plan_id") @db.Uuid
  status          BillingSubscriptionStatus @default(active)
  branchCount     Int                       @default(1) @map("branch_count")
  monthlyAmount   Decimal                   @map("monthly_amount") @db.Decimal(12, 2)
  nextPaymentDate DateTime                  @map("next_payment_date") @db.Date
  gracePeriodEnd  DateTime?                 @map("grace_period_end") @db.Date
  blockedAt       DateTime?                 @map("blocked_at")
  startDate       DateTime                  @map("start_date") @db.Date
  endDate         DateTime?                 @map("end_date") @db.Date
  createdAt       DateTime                  @default(now()) @map("created_at")
  updatedAt       DateTime                  @updatedAt @map("updated_at")

  organization Organization     @relation(fields: [organizationId], references: [id])
  plan         BillingPlan      @relation(fields: [planId], references: [id])
  invoices     BillingInvoice[]

  @@index([organizationId])
  @@map("billing_subscriptions")
}

// Счета на оплату
model BillingInvoice {
  id             String               @id @default(uuid()) @db.Uuid
  subscriptionId String               @map("subscription_id") @db.Uuid
  organizationId String               @map("organization_id") @db.Uuid
  number         String               @unique
  amount         Decimal              @db.Decimal(12, 2)
  status         BillingInvoiceStatus @default(pending)
  periodStart    DateTime             @map("period_start") @db.Date
  periodEnd      DateTime             @map("period_end") @db.Date
  dueDate        DateTime             @map("due_date") @db.Date
  paidAt         DateTime?            @map("paid_at")
  paidAmount     Decimal?             @map("paid_amount") @db.Decimal(12, 2)
  comment        String?
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")

  subscription BillingSubscription @relation(fields: [subscriptionId], references: [id])
  organization Organization        @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([status])
  @@map("billing_invoices")
}

// === БИЛЛИНГ ENUMS ===

enum AdminRole {
  superadmin
  support
  development
  billing
}

enum BillingStatus {
  active
  grace_period
  blocked
}

enum BillingSubscriptionStatus {
  active
  grace_period
  blocked
  cancelled
}

enum BillingInvoiceStatus {
  pending
  paid
  overdue
  cancelled
}

// === ЛИЧНЫЙ КАБИНЕТ КЛИЕНТА ===

model ClientPortalToken {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  clientId       String    @map("client_id") @db.Uuid
  token          String    @unique
  isActive       Boolean   @default(true) @map("is_active")
  pdnConsent     Boolean   @default(false) @map("pdn_consent")
  pdnConsentDate DateTime? @map("pdn_consent_date")
  lastAccessedAt DateTime? @map("last_accessed_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  client Client @relation(fields: [clientId], references: [id])

  @@index([token])
  @@index([tenantId, clientId])
  @@map("client_portal_tokens")
}

// === ЗАКРЫТИЕ ПЕРИОДА ===

model Period {
  id         String       @id @default(uuid()) @db.Uuid
  tenantId   String       @map("tenant_id") @db.Uuid
  year       Int
  month      Int
  status     PeriodStatus @default(open)
  closedAt   DateTime?    @map("closed_at")
  closedBy   String?      @map("closed_by") @db.Uuid
  reopenedAt DateTime?    @map("reopened_at")
  reopenedBy String?      @map("reopened_by") @db.Uuid
  comment    String?
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")

  organization       Organization @relation(fields: [tenantId], references: [id])
  closedByEmployee   Employee?    @relation("periodClosedBy", fields: [closedBy], references: [id])
  reopenedByEmployee Employee?    @relation("periodReopenedBy", fields: [reopenedBy], references: [id])

  @@unique([tenantId, year, month])
  @@map("periods")
}

enum PeriodStatus {
  open
  closed
  reopened
}

// === ПРОБНЫЕ ЗАНЯТИЯ ===

model TrialLesson {
  id            String      @id @default(uuid()) @db.Uuid
  tenantId      String      @map("tenant_id") @db.Uuid
  clientId      String      @map("client_id") @db.Uuid
  wardId        String?     @map("ward_id") @db.Uuid
  groupId       String      @map("group_id") @db.Uuid
  lessonId      String?     @map("lesson_id") @db.Uuid
  status        TrialStatus @default(scheduled)
  scheduledDate DateTime    @map("scheduled_date") @db.Date
  attendedAt    DateTime?   @map("attended_at")
  comment       String?
  createdBy     String?     @map("created_by") @db.Uuid
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  organization Organization @relation(fields: [tenantId], references: [id])
  client       Client       @relation(fields: [clientId], references: [id])
  ward         Ward?        @relation(fields: [wardId], references: [id])
  group        Group        @relation(fields: [groupId], references: [id])
  lesson       Lesson?      @relation(fields: [lessonId], references: [id])

  @@index([tenantId, clientId])
  @@index([tenantId, groupId, scheduledDate])
  @@map("trial_lessons")
}

enum TrialStatus {
  scheduled
  attended
  no_show
  cancelled
}

// === ТРАНЗАКЦИИ БАЛАНСА КЛИЕНТА ===

model ClientBalanceTransaction {
  id             String                 @id @default(uuid()) @db.Uuid
  tenantId       String                 @map("tenant_id") @db.Uuid
  clientId       String                 @map("client_id") @db.Uuid
  type           BalanceTransactionType
  amount         Decimal                @db.Decimal(12, 2)
  subscriptionId String?                @map("subscription_id") @db.Uuid
  paymentId      String?                @map("payment_id") @db.Uuid
  comment        String?
  createdBy      String?                @map("created_by") @db.Uuid
  createdAt      DateTime               @default(now()) @map("created_at")

  organization Organization  @relation(fields: [tenantId], references: [id])
  client       Client        @relation(fields: [clientId], references: [id])
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])
  payment      Payment?      @relation(fields: [paymentId], references: [id])

  @@index([tenantId, clientId])
  @@index([tenantId, createdAt])
  @@map("client_balance_transactions")
}

enum BalanceTransactionType {
  payment_received
  subscription_remainder
  refund
  correction
  transfer_to_subscription
}

enum NotificationType {
  empty_group
  unmarked_lesson
  overdue_payment
  trial_reminder
  period_close
  linked_discount_warning
}

enum AdminBonusType {
  per_trial
  per_sale
  per_upsale
}

// === MVP-ТАБЛИЦЫ ===

// Производственный календарь — праздничные и рабочие дни
model ProductionCalendar {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  date      DateTime @db.Date
  isWorking Boolean  @map("is_working")
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, date])
  @@index([tenantId])
  @@map("production_calendar")
}

// Шаблон скидки — предопределённые типы скидок организации
model DiscountTemplate {
  id          String            @id @default(uuid()) @db.Uuid
  tenantId    String            @map("tenant_id") @db.Uuid
  name        String
  type        DiscountType
  valueType   DiscountValueType @map("value_type")
  value       Decimal           @db.Decimal(12, 2)
  isStackable Boolean           @default(false) @map("is_stackable")
  isActive    Boolean           @default(true) @map("is_active")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  organization Organization @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("discount_templates")
}

// Плановый расход — план платежей по категории за месяц
model PlannedExpense {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  categoryId    String   @map("category_id") @db.Uuid
  employeeId    String?  @map("employee_id") @db.Uuid
  branchId      String?  @map("branch_id") @db.Uuid
  periodYear    Int      @map("period_year")
  periodMonth   Int      @map("period_month")
  plannedAmount Decimal  @map("planned_amount") @db.Decimal(12, 2)
  paidAmount    Decimal  @default(0) @map("paid_amount") @db.Decimal(12, 2)
  comment       String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  organization Organization    @relation(fields: [tenantId], references: [id])
  category     ExpenseCategory @relation(fields: [categoryId], references: [id])
  employee     Employee?       @relation("PlannedExpenseEmployee", fields: [employeeId], references: [id])
  branch       Branch?         @relation(fields: [branchId], references: [id])

  @@index([tenantId, periodYear, periodMonth])
  @@map("planned_expenses")
}

// Настройки бонусов администратора — мотивация за продажи, пробные, допродажи
model AdminBonusSettings {
  id         String         @id @default(uuid()) @db.Uuid
  tenantId   String         @map("tenant_id") @db.Uuid
  branchId   String?        @map("branch_id") @db.Uuid
  employeeId String         @map("employee_id") @db.Uuid
  bonusType  AdminBonusType @map("bonus_type")
  amount     Decimal        @db.Decimal(12, 2)
  channels   Json?
  isActive   Boolean        @default(true) @map("is_active")
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")

  organization Organization @relation(fields: [tenantId], references: [id])
  branch       Branch?      @relation(fields: [branchId], references: [id])
  employee     Employee     @relation(fields: [employeeId], references: [id])

  @@index([tenantId])
  @@map("admin_bonus_settings")
}

// Уведомление (колокольчик) — пустые группы, неотмеченные занятия, просроченные оплаты
model Notification {
  id         String           @id @default(uuid()) @db.Uuid
  tenantId   String           @map("tenant_id") @db.Uuid
  employeeId String           @map("employee_id") @db.Uuid
  type       NotificationType
  title      String
  message    String?
  entityType String?          @map("entity_type")
  entityId   String?          @map("entity_id") @db.Uuid
  isRead     Boolean          @default(false) @map("is_read")
  createdAt  DateTime         @default(now()) @map("created_at")

  organization Organization @relation(fields: [tenantId], references: [id])
  employee     Employee     @relation(fields: [employeeId], references: [id])

  @@index([tenantId, employeeId, isRead])
  @@index([tenantId, createdAt])
  @@map("notifications")
}

// Комментарий по непродлённому абонементу (отчёт «Непродлённые»)
model UnprolongedComment {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  clientId       String   @map("client_id") @db.Uuid
  subscriptionId String   @map("subscription_id") @db.Uuid
  periodYear     Int      @map("period_year")
  periodMonth    Int      @map("period_month")
  comment        String
  createdAt      DateTime @default(now()) @map("created_at")
  createdBy      String?  @map("created_by") @db.Uuid

  organization Organization @relation(fields: [tenantId], references: [id])
  client       Client       @relation(fields: [clientId], references: [id])
  subscription Subscription @relation(fields: [subscriptionId], references: [id])
  creator      Employee?    @relation("UnprolongedCommentCreator", fields: [createdBy], references: [id])

  @@index([tenantId, periodYear, periodMonth])
  @@map("unprolonged_comments")
}

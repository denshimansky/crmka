generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// === АВТОРИЗАЦИЯ (NextAuth) ===

model Account {
  id                String  @id @default(uuid()) @db.Uuid
  userId            String  @map("user_id") @db.Uuid
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id") @db.Uuid
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id            String    @id @default(uuid()) @db.Uuid
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  name          String?
  image         String?

  // Связь с сотрудником (и через него — с организацией)
  employeeId String?   @unique @map("employee_id") @db.Uuid
  employee   Employee? @relation(fields: [employeeId], references: [id])

  accounts Account[]
  sessions Session[]

  @@map("users")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// === МУЛЬТИТЕНАНТ ===

model Organization {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  legalName String?  @map("legal_name")
  inn       String?
  phone     String?
  email     String?

  // Настройки
  salaryDay1         Int?     @default(15) @map("salary_day_1")
  salaryDay2         Int?     @default(30) @map("salary_day_2")
  payForAbsence      Boolean  @default(false) @map("pay_for_absence")
  attendanceDeadline Int      @default(14) @map("attendance_deadline")
  debtLimit          Decimal? @db.Decimal(12, 2) @map("debt_limit")
  makeupDaysLimit    Int?     @map("makeup_days_limit")
  makeupDeadlineDays Int?     @map("makeup_deadline_days")
  roleDisplayNames   Json?    @map("role_display_names")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  branches   Branch[]
  employees  Employee[]
  directions Direction[]
  clients    Client[]

  @@map("organizations")
}

model Branch {
  id                String    @id @default(uuid()) @db.Uuid
  tenantId          String    @map("tenant_id") @db.Uuid
  name              String
  address           String?
  workingHoursStart String?   @map("working_hours_start")
  workingHoursEnd   String?   @map("working_hours_end")
  workingDays       Json?     @map("working_days")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")

  organization     Organization     @relation(fields: [tenantId], references: [id])
  rooms            Room[]
  employeeBranches EmployeeBranch[]
  clients          Client[]

  @@index([tenantId])
  @@map("branches")
}

model Room {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  branchId  String    @map("branch_id") @db.Uuid
  name      String
  capacity  Int       @default(15)
  createdAt DateTime  @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")

  branch Branch @relation(fields: [branchId], references: [id])

  @@index([tenantId])
  @@map("rooms")
}

model Employee {
  id               String    @id @default(uuid()) @db.Uuid
  tenantId         String    @map("tenant_id") @db.Uuid
  login            String
  passwordHash     String    @map("password_hash")
  email            String?
  firstName        String    @map("first_name")
  lastName         String    @map("last_name")
  middleName       String?   @map("middle_name")
  phone            String?
  birthDate        DateTime? @map("birth_date") @db.Date
  role             Role
  customPermissions Json?    @map("custom_permissions")
  isActive         Boolean   @default(true) @map("is_active")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  organization     Organization     @relation(fields: [tenantId], references: [id])
  user             User?
  employeeBranches EmployeeBranch[]
  salaryRates      SalaryRate[]
  assignedClients  Client[]         @relation("AssignedClients")

  @@unique([tenantId, login])
  @@index([tenantId])
  @@map("employees")
}

// === КЛИЕНТЫ ===

model Client {
  id                     String             @id @default(uuid()) @db.Uuid
  tenantId               String             @map("tenant_id") @db.Uuid
  firstName              String?            @map("first_name")
  lastName               String?            @map("last_name")
  patronymic             String?
  phone                  String?
  phone2                 String?
  email                  String?
  socialLink             String?            @map("social_link")
  funnelStatus           FunnelStatus       @default(new) @map("funnel_status")
  clientStatus           ClientWorkStatus?  @map("client_status")
  segment                ClientSegment      @default(new_client) @map("segment")
  totalSubscriptionsCount Int               @default(0) @map("total_subscriptions_count")
  channelId              String?            @map("channel_id") @db.Uuid
  assignedTo             String?            @map("assigned_to") @db.Uuid
  branchId               String?            @map("branch_id") @db.Uuid
  nextContactDate        DateTime?          @map("next_contact_date") @db.Date
  blacklistReason        String?            @map("blacklist_reason")
  blacklistedBy          String?            @map("blacklisted_by") @db.Uuid
  withdrawalReasonId     String?            @map("withdrawal_reason_id") @db.Uuid
  withdrawalDate         DateTime?          @map("withdrawal_date") @db.Date
  clientBalance          Decimal            @default(0) @db.Decimal(12, 2) @map("client_balance")
  promisedPaymentDate    DateTime?          @map("promised_payment_date") @db.Date
  firstPaymentDate       DateTime?          @map("first_payment_date") @db.Date
  firstPaidLessonDate    DateTime?          @map("first_paid_lesson_date") @db.Date
  saleDate               DateTime?          @map("sale_date") @db.Date
  moneyLtv               Decimal            @default(0) @db.Decimal(12, 2) @map("money_ltv")
  monthsLtv              Int                @default(0) @map("months_ltv")
  comment                String?
  createdBy              String?            @map("created_by") @db.Uuid
  createdAt              DateTime           @default(now()) @map("created_at")
  updatedAt              DateTime           @updatedAt @map("updated_at")
  deletedAt              DateTime?          @map("deleted_at")

  organization Organization @relation(fields: [tenantId], references: [id])
  branch       Branch?      @relation(fields: [branchId], references: [id])
  assignee     Employee?    @relation("AssignedClients", fields: [assignedTo], references: [id])
  wards        Ward[]

  @@index([tenantId, funnelStatus])
  @@index([tenantId, clientStatus])
  @@index([tenantId, phone])
  @@map("clients")
}

model Ward {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  clientId  String    @map("client_id") @db.Uuid
  firstName String    @map("first_name")
  lastName  String?   @map("last_name")
  birthDate DateTime? @map("birth_date") @db.Date
  notes     String?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("wards")
}

// === НАПРАВЛЕНИЯ ===

model Direction {
  id           String    @id @default(uuid()) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  name         String
  lessonPrice  Decimal   @db.Decimal(12, 2) @map("lesson_price")
  lessonDuration Int     @default(45) @map("lesson_duration")
  trialPrice   Decimal?  @db.Decimal(12, 2) @map("trial_price")
  trialFree    Boolean   @default(false) @map("trial_free")
  color        String?
  sortOrder    Int       @default(0) @map("sort_order")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  organization Organization @relation(fields: [tenantId], references: [id])
  salaryRates  SalaryRate[]

  @@index([tenantId])
  @@map("directions")
}

// === ПРИВЯЗКА СОТРУДНИКА К ФИЛИАЛАМ ===

model EmployeeBranch {
  id         String @id @default(uuid()) @db.Uuid
  employeeId String @map("employee_id") @db.Uuid
  branchId   String @map("branch_id") @db.Uuid

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  branch   Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([employeeId, branchId])
  @@map("employee_branches")
}

// === СТАВКИ ЗП ===

model SalaryRate {
  id           String      @id @default(uuid()) @db.Uuid
  tenantId     String      @map("tenant_id") @db.Uuid
  employeeId   String      @map("employee_id") @db.Uuid
  directionId  String?     @map("direction_id") @db.Uuid
  scheme       SalaryScheme
  ratePerStudent Decimal?  @db.Decimal(12, 2) @map("rate_per_student")
  ratePerLesson  Decimal?  @db.Decimal(12, 2) @map("rate_per_lesson")
  fixedPerShift  Decimal?  @db.Decimal(12, 2) @map("fixed_per_shift")
  createdAt    DateTime    @default(now()) @map("created_at")

  employee  Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  direction Direction? @relation(fields: [directionId], references: [id])

  @@index([tenantId])
  @@map("salary_rates")
}

// === ЛОГ АУДИТА ===

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  employeeId String   @map("employee_id") @db.Uuid
  action     String
  entity     String
  entityId   String?  @map("entity_id")
  details    Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([tenantId, createdAt])
  @@map("audit_logs")
}

// === ENUMS ===

enum Role {
  owner
  manager
  admin
  instructor
  readonly
}

enum SalaryScheme {
  per_student
  per_lesson
  fixed_plus_per_student
}

enum FunnelStatus {
  new
  trial_scheduled
  trial_attended
  awaiting_payment
  active_client
  potential
  non_target
  blacklisted
  archived
}

enum ClientWorkStatus {
  active
  upsell
  churned
  returning
  archived
}

enum ClientSegment {
  new_client
  standard
  regular
  vip
}

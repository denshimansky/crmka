# Database (локальная разработка)
DATABASE_URL="postgresql://crmka:crmka_secret@localhost:5432/crmka?schema=public"

# NextAuth — в production обязательно ≥32 символов (иначе модуль падает на старте).
# Генерация: `openssl rand -hex 32`
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-to-random-string"

# Опционально — отдельные секреты для admin-сессии и клиентского портала.
# Если не заданы — используется NEXTAUTH_SECRET.
# ADMIN_JWT_SECRET=""
# PORTAL_JWT_SECRET=""

# App
NODE_ENV="development"

# Секрет для авторизации ежедневных cron-эндпоинтов (/api/cron/*).
# Тот же самый должен быть прописан в GitHub Secrets как CRON_SECRET —
# воркфлоу .github/workflows/*.yml шлют его в заголовке Authorization.
# Генерация: `openssl rand -hex 32`
CRON_SECRET=""

# T-Bank Business API (Invoicing)
# Токен из ЛК Т-Бизнеса: https://www.tbank.ru/business/open-api/
TBANK_API_TOKEN=""
# "true" = sandbox (по умолчанию), "false" = production
TBANK_SANDBOX="true"
# Секрет для верификации webhook (произвольная строка)
TBANK_WEBHOOK_SECRET=""

# SMTP — собственный почтовый сервер (docker-mailserver на mail.umnayacrm.ru)
# Если не задано — письма не отправляются, линки восстановления логируются в консоль.
SMTP_HOST="mail.umnayacrm.ru"
SMTP_PORT="465"
SMTP_USER="noreply@umnayacrm.ru"
SMTP_PASS=""
MAIL_FROM="Умная CRM <noreply@umnayacrm.ru>"

# AI-ассистент CRM (/api/ai/chat) — OpenAI. Без ключа помощник отвечает
# «временно недоступен». Ключ: https://platform.openai.com/api-keys
OPENAI_API_KEY=""
# Модель по умолчанию gpt-5.4-mini. Альтернативы: gpt-5.4-nano / gpt-5.5.
OPENAI_MODEL=""
